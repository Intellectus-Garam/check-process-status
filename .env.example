# Copy to .env on each machine (gitignored) and fill in.

# Slack Incoming Webhook URL. If empty, watch.sh prints the report to stdout
# instead of posting (useful for a first dry run).
SLACK_WEBHOOK_URL=""

# Optional overrides (defaults shown):
# WAIT_SECONDS=60          # gap between the two subscriber pane captures
# MEM_THRESHOLD_MB=1500    # per-process RSS alert threshold
